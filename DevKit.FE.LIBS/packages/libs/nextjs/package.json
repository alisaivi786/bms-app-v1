{
	"name": "@devkit/nextjs",
	"version": "12.2.1",
	"majorVersionRestrict": "12",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"license": "UNLICENSED",
	"type": "module",
	"scripts": {
		"build": "rollup -c",
		"prepack": "npm run build",
		"lint": "eslint ./src",
		"lint-fix": "eslint --fix ./src",
		"type-check": "npx tsc --emitDeclarationOnly false --noEmit",
		"test": "jest",
		"test:cover": "jest --coverage",
		"dev": "storybook dev -p 6008",
		"start": "concurrently \"test:generate-output:watch\" \"storybook dev -p 6008\"",
		"storybook:build": "storybook build --disable-telemetry --output-dir=../../../.build/nextjs"
	},
	"files": [
		"./dist",
		"./server.js",
		"./server.d.ts"
	],
	"nx": {
		"tags": [
			"@devkit/nextjs"
		]
	},
	"devDependencies": {
		"@happy-dom/jest-environment": "^18.0.1",
		"@devkit/eslint-config": "workspace:*",
		"@devkit/rollup-config": "workspace:*",
		"@devkit/ts-config": "workspace:*",
		"@devkit/utilities": "workspace:*",
		"@devkit/web": "workspace:*",
		"@storybook/addon-docs": "9.1.1",
		"@storybook/addon-links": "9.1.1",
		"@storybook/addons": "^7.0.26",
		"@storybook/preset-scss": "^1.0.3",
		"@storybook/react": "9.1.1",
		"@storybook/react-vite": "9.1.1",
		"@types/jest": "^29.2.1",
		"@types/lodash": "^4.14.194",
		"@types/react": "^18.2.21",
		"@types/uuid": "^9.0.4",
		"concurrently": "^8.2.0",
		"eslint-plugin-storybook": "9.1.1",
		"jest": "^29.2.1",
		"jest-environment-jsdom": "^29.5.0",
		"lodash": "^4.17.21",
		"next": "14.2.30",
		"next-i18next": "13.2.2",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"react-i18next": "12.2.2",
		"storybook": "9.1.1",
		"ts-jest": "^29.1.0"
	},
	"peerDependencies": {
		"@devkit/utilities": "12.x",
		"@devkit/web": "12.x",
		"lodash": ">= 4.17.21",
		"next": ">= 14.0.3",
