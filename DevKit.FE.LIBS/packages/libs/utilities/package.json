{
	"name": "@devkit/utilities",
	"version": "12.4.12",
	"majorVersionRestrict": "12",
	"main": "dist/cjs/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"require": "./dist/cjs/index.js",
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./dist/*": {
			"require": "./dist/cjs/*.js",
			"import": "./dist/*.js",
			"types": "./dist/*.d.ts",
			"default": "./dist/*.js"
		}
	},
	"engines": {
		"node": ">=10",
		"pnpm": ">=7"
	},
	"scripts": {
		"test": "TZ=UTC jest",
		"test:cover": "jest --coverage",
		"test:watch": "jest --watchAll",
		"build": "rollup -c",
		"prepack": "npm run build",
		"lint": "eslint ./src",
		"lint-fix": "eslint --fix ./src",
		"type-check": "npx tsc --project tsconfig.ts-check.json",
		"dev": "storybook dev -p 6009",
		"start": "concurrently \"test:generate-output:watch\" \"storybook dev -p 6009\"",
		"storybook:build": "storybook build --disable-telemetry --output-dir=../../../.build/utilities"
	},
	"files": [
		"./dist"
	],
	"nx": {
		"tags": [
			"@devkit/utilities"
		]
	},
	"devDependencies": {
		"@happy-dom/jest-environment": "^18.0.1",
		"@devkit/config": "workspace:*",
		"@devkit/eslint-config": "workspace:*",
		"@devkit/rollup-config": "workspace:*",
		"@devkit/ts-config": "workspace:*",
		"@reduxjs/toolkit": "1.9.5",
		"@storybook/addon-docs": "9.1.1",
		"@storybook/addon-links": "9.1.1",
		"@storybook/addons": "^7.0.26",
		"@storybook/preset-scss": "^1.0.3",
		"@storybook/react": "9.1.1",
		"@storybook/react-vite": "9.1.1",
		"@testing-library/jest-dom": "^5.16.5",
		"@testing-library/react": "^14.0.0",
		"@types/jest": "^29.2.1",
		"@types/lodash": "^4.14.194",
		"@types/react": "^18.2.21",
		"concurrently": "^8.2.0",
		"eslint": "^8.40.0",
		"eslint-plugin-storybook": "9.1.1",
		"jest": "^29.2.1",
		"jest-environment-jsdom": "^29.5.0",
		"lodash": "^4.17.21",
		"react": "18.2.0",
		"react-dom": "18.2.0",
		"redux-persist": "6.0.0",
		"storybook": "9.1.1",
		"ts-jest": "^29.1.0",
		"yup": "1.1.1",
		"zod": "~3.22.2"
	},
	"peerDependencies": {
		"@reduxjs/toolkit": ">= 1.9.1",
		"date-fns": "2.x",
		"date-fns-tz": "2.x",
		"lodash": ">= 4.17.21",
		"react": ">= 18.1.0",
		"redux-persist": ">= 6.0.0",
		"yup": ">= 0.32.11",
		"zod": "~3.22.2"
	},
	"dependencies": {
		"@hookform/resolvers": "3.3.0",
		"date-fns": "2.30.0",
		"date-fns-tz": "2.0.0",
		"react-hook-form": "7.45.2"
	}
}
