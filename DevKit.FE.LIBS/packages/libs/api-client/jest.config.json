{
	"preset": "ts-jest",
	"testEnvironment": "@happy-dom/jest-environment",
	"transform": {
		"^.+\\.tsx?$": [
			"ts-jest",
			{
				"tsconfig": {
					"jsx": "react",
					"esModuleInterop": true,
					"allowSyntheticDefaultImports": true
				}
			}
		]
	},
	"setupFilesAfterEnv": ["@testing-library/jest-dom"],
	"collectCoverageFrom": [
		"./src/**/*.{ts,tsx}",
		"!./src/**/*.stories.tsx",
		"!./src/**/*.test.{ts,tsx}",
		"!./src/**/*.spec.{ts,tsx}",
		"!./src/index.ts",
		"!./src/types.ts"
	],
	"coverageDirectory": "coverage",
	"modulePathIgnorePatterns": ["node_modules", "jest-test-results.json", "dist", "stories"],
	"coverageThreshold": {
		"global": {
			"lines": 70,
			"functions": 70,
			"branches": 65,
			"statements": 70
		}
	},
	"testMatch": ["**/__tests__/**/*.test.ts?(x)", "**/?(*.)+(spec|test).ts?(x)"],
	"moduleNameMapper": {
		"^@/(.*)$": "<rootDir>/src/$1"
	}
}
