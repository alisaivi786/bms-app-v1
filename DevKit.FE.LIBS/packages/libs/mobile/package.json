{
	"name": "@devkit/mobile",
	"version": "12.6.99",
	"majorVersionRestrict": "12",
	"main": "dist/cjs/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"require": "./dist/cjs/index.js",
			"import": "./dist/index.js"
		},
		"./dist/*": {
			"types": "./dist/*.d.ts",
			"require": "./dist/cjs/*.js",
			"import": "./dist/*.js"
		}
	},
	"files": [
		"./dist",
		"./src",
		"./index.ts"
	],
	"nx": {
		"tags": [
			"@devkit/mobile"
		]
	},
	"scripts": {
		"bundle:install": "bundle install",
		"pods:install": "cd ios && bundle exec pod install",
		"pods:repo:update": "cd ios && bundle exec pod repo update",
		"lint": "eslint ./src --ext .js,.jsx,.ts,.tsx",
		"lint-fix": "eslint --fix ./src --ext .js,.jsx,.ts,.tsx",
		"storybook": "STORYBOOK_ENABLED='true' react-native start --reset-cache",
		"storybook:ios": "STORYBOOK_ENABLED='true' react-native run-ios --no-packager",
		"storybook:android": "STORYBOOK_ENABLED='true' react-native run-android --no-packager",
		"storybook:build": "STORYBOOK_WEB=true storybook build --output-dir=../../../.build/mobile",
		"storybook-generate": "sb-rn-get-stories --config-path .ondevice",
		"storybook:web": "storybook dev -p 6006",
		"prepack": "npm run build",
		"build-storybook": "storybook build",
		"build": "rollup -c",
		"type-check": "npx tsc --emitDeclarationOnly false --noEmit",
		"test": "jest",
		"test:watch": "jest --watchAll",
		"test:cover": "jest --coverage"
	},
	"engines": {
		"node": ">=18"
	},
	"dependencies": {
		"@backpackapp-io/react-native-toast": "^0.13.0",
