{
	"name": "@devkit/root",
	"version": "0.0.0",
	"license": "MIT",
	"scripts": {
		"bootstrap": "bash scripts/bootstrap.sh",
		"verify": "bash scripts/verify-tools.sh",
		"api-client:dev": "nx dev @devkit/api-client",
		"web:dev": "nx dev @devkit/web",
		"web:start": "cd packages/libs/web && pnpm start",
		"web:build": "nx build @devkit/web",
		"charts:start": "cd packages/libs/charts && pnpm start",
		"utilities:dev": "nx dev @devkit/utilities",
		"utilities:build": "nx build @devkit/utilities",
		"nextjs:dev": "nx dev @devkit/nextjs",
		"nextjs:build": "nx build @devkit/nextjs",
		"config:build": "nx build @devkit/config",
		"icons:build": "nx build @devkit/icons",
		"mobile:build": "nx build @devkit/mobile",
		"mobile:bundle:install": "nx bundle:install @devkit/mobile",
		"mobile:pods:install": "nx pods:install @devkit/mobile",
		"mobile:pods:repo:update": "nx pods:repo:update @devkit/mobile",
		"mobile:storybook": "nx storybook @devkit/mobile",
		"mobile:storybook:ios": "nx storybook:ios @devkit/mobile",
		"mobile:storybook:android": "nx storybook:android @devkit/mobile",
		"mobile:storybook:web": "nx storybook:web @devkit/mobile",
		"prettier": "prettier --write \"**/**/!(dist|node_modules|icons)/**/**.{js,ts,tsx,jsx,json}\"",
		"clean": "find . -name 'node_modules' -type d -prune -print -exec rm -rf '{}' \\;",
		"clean-build": "find . -name 'dist' -type d -prune -print -exec rm -rf '{}' \\;",
		"lint": "nx run-many --target=lint",
		"lint-fix": "nx run-many --target=lint-fix",
		"type-check": "nx run-many --target=type-check",
		"test": "nx run-many --target=test",
		"test:cover": "nx run-many --target=test:cover",
		"build": "nx run-many --target=build",
		"start": "nx dev @devkit/web",
		"dev": "nx root-dev @devkit/shared-storybook",
		"build-no-cache": "nx run-many --target=build --skip-nx-cache",
		"storybook:build": "rm -rf .build && mkdir -p .build && cp -r .server/* .build && nx run-many --target=storybook:build --skip-nx-cache",
		"scripts:upgrade": "cd packages/libs/web && npx devkit-upgrade",
		"check-major-version-policy": "node ./scripts/avoid-major-version-push.mjs"
	},
	"private": true,
	"pnpm": {
		"peerDependencyRules": {
			"allowAny": [
				"typescript"
			],
			"allowedVersions": {
				"react": "18",
				"react-dom": "18"
			}
		},
		"patchedDependencies": {
			"@gorhom/bottom-sheet@5.2.6": "patches/@gorhom__bottom-sheet@5.2.6.patch"
		}
	},
	"devDependencies": {
		"@babel/runtime": "^7.20.0",
		"@changesets/cli": "^2.26.1",
		"@devkit/eslint-config": "workspace:*",
		"@devkit/prettier-config": "workspace:*",
		"@devkit/upgrade": "workspace:*",
		"@nx/eslint-plugin": "^16.5.1",
		"@rollup/plugin-commonjs": "^25.0.2",
		"@rollup/plugin-node-resolve": "^15.1.0",
		"@rollup/plugin-typescript": "^11.1.1",
		"jest": "^29.2.1",
		"nx": "16.5.1",
		"prettier": "^2.8.8",
		"rimraf": "^5.0.0",
		"rollup": "^3.25.2",
		"rollup-plugin-analyzer": "^4.0.0",
		"rollup-plugin-dts": "^5.3.0",
		"rollup-plugin-postcss": "^4.0.2",
		"rollup-plugin-preserve-directives": "^0.4.0",
		"semver": "^7.6.0",
		"tslib": "^2.5.3",
		"typescript": "^5.1.3"
	},
	"packageManager": "pnpm@10.9.0"
}
